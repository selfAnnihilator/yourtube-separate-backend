PORT=5000
DB_URL=mongodb://127.0.0.1:27017/yourtube
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
TRANSLATION_PROVIDER=deepl
DEEPL_API_KEY=your-deepl-api-key
# Optional. Defaults to https://api-free.deepl.com for DeepL.
TRANSLATION_API_URL=https://api-free.deepl.com
# Optional. DeepL language detection is beta/opt-in, so leave false unless your key has access.
DEEPL_DETECT_LANGUAGE_ENABLED=false
